<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">

    <!-- The Icon -->
    <ImageView
        android:id="@+id/icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="@id/label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/label"
        app:tint="?android:textColorSecondary"
        tools:src="@drawable/ic_terminal_24" />

    <TextView
        android:id="@+id/label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:fontFamily="monospace"
        android:textAppearance="?textAppearanceTitleMedium"
        android:textColor="?android:textColorPrimary"
        app:layout_constraintEnd_toStartOf="@id/status_container"
        app:layout_constraintStart_toEndOf="@id/icon"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Execute command" />

    <FrameLayout
        android:id="@+id/status_container"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:layout_constraintBottom_toBottomOf="@id/label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/label">

        <View
            android:id="@+id/status_pending"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:background="@drawable/shape_circle_icon_background"
            android:backgroundTint="?colorSecondary" />

        <ProgressBar
            android:id="@+id/status_running"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/status_completed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_server_ok_24dp"
            android:visibility="gone"
            app:tint="?colorPrimary" />

        <ImageView
            android:id="@+id/status_failed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_server_error_24dp"
            android:visibility="gone"
            app:tint="?colorError" />
    </FrameLayout>

    <TextView
        android:id="@+id/user_error_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?textAppearanceBodyMedium"
        android:textColor="?colorError"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/label"
        app:layout_constraintStart_toStartOf="@id/label"
        app:layout_constraintTop_toBottomOf="@id/label"
        tools:text="@string/start_error_pairing_required"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/action_button"
        style="?attr/materialButtonTonalStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="0dp"
        android:paddingVertical="4dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/label"
        app:layout_constraintTop_toBottomOf="@id/user_error_message"
        tools:text="Pair"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/expand_trigger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@id/label"
        app:layout_constraintTop_toBottomOf="@id/action_button"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error details"
            android:textAppearance="?textAppearanceLabelSmall"
            android:textColor="?android:textColorSecondary" />

        <ImageView
            android:id="@+id/expand_indicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_forward"
            app:tint="?android:textColorSecondary" />
    </LinearLayout>

    <TextView
        android:id="@+id/stack_trace"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/colorSurfaceVariant"
        android:fontFamily="monospace"
        android:padding="8dp"
        android:textAppearance="?textAppearanceLabelSmall"
        android:textColor="?colorOnSurfaceVariant"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/label"
        app:layout_constraintTop_toBottomOf="@id/expand_trigger"
        tools:text="java.net.ConnectException: Connection refused..."
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>