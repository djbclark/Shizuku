<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainer</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="contentPadding">24dp</item>
        <item name="android:descendantFocusability">afterDescendants</item>
    </style>

    <style name="SectionHeader" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="CardIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/shape_circle_icon_background</item>
        <item name="android:tint">?colorOnPrimaryContainer</item>
        <item name="android:tintMode">src_in</item>
        <item name="android:backgroundTint">?colorPrimaryContainer</item>
        <item name="android:backgroundTintMode">src_in</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

    <style name="GrantPermissions" parent="@style/Theme.App">
        <item name="android:colorBackground">?colorBackgroundFloating</item>
        <item name="android:colorBackgroundCacheHint">@null</item>

        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>

    <style name="TutorialText">
        <item name="android:textAppearance">?textAppearanceBodyMedium</item>
        <item name="android:minHeight">24dp</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="CommandBlock" parent="TutorialText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:background">?colorSurfaceVariant</item>
        <item name="android:padding">12dp</item>
        <item name="android:elevation">1dp</item>
        <item name="android:textColor">?android:textColorSecondary</item>
        <item name="android:textIsSelectable">true</item>
    </style>

    <style name="DialogCard" parent="@style/Widget.Material3.CardView.Filled">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:checkable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:clipChildren">false</item>
        <item name="android:clipToPadding">false</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="contentPadding">24dp</item>
        <item name="cardBackgroundColor">?colorSecondaryContainer</item>
    </style>

    <style name="GrantPermissionsButtons">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginEnd">24dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?colorOnPrimaryContainer</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="GrantPermissionsButtons.Top">
        <item name="android:background">@drawable/grant_permissions_buttons_top</item>
        <item name="android:layout_marginBottom">2dp</item>
    </style>

    <style name="GrantPermissionsButtons.Bottom">
        <item name="android:background">@drawable/grant_permissions_buttons_bottom</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <style name="IntentsLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">?textAppearanceLabelLarge</item>
        <item name="android:textColor">?colorPrimary</item>
    </style>

</resources>
